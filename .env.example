# LLM Provider configuration: 'gemini', 'openai', 'anthropic', or 'groq'
LLM_PROVIDER=gemini

# API Keys (fill in the one you plan to use)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (e.g. 'llama-3.3-70b-specdec', 'mixtral-8x7b-32768')
GROQ_MODEL=llama-3.3-70b-specdec

# Embedding and Reranking Models configuration
# Default: 'BAAI/bge-m3' for multilingual, or 'all-MiniLM-L6-v2' for a lightweight alternative
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# API Port & Host
API_HOST=127.0.0.1
API_PORT=8000
